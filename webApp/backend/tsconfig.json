{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment & Module Resolution
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
    // "lib": ["esnext"],
    "lib": ["esnext", "ES2020", "DOM"],
    "types": ["node", "jest"],
    "esModuleInterop": true, //allows TypeScript to correctly import CommonJS modules (like dotenv) using modern ES syntax


    //  path alis for import 
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },


    // Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Strictness & Safety
    "strict": true,
    
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,

    // Optional flags
    // "noImplicitReturns": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
