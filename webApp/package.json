{
  "name": "base-code",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "_moduleAliases": {
    "@src": "backend/dist"
  },
  "scripts": {
    "seed": "cd backend && npx ts-node -r tsconfig-paths/register src/database/constructDatabase.ts",
    "test": "jest --coverage",
    "dev": "npm run build:backend && concurrently \"tsc -w -p backend/tsconfig.json\" \"npx tsc-alias -p backend/tsconfig.json -w\" \"tsc -w -p frontend/tsconfig.json\" \"nodemon backend/dist/server.js\"",
    "build:backend": "tsc -p backend/tsconfig.json && npx tsc-alias -p backend/tsconfig.json",
    "build:frontend": "tsc -p frontend/tsconfig.json",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "npm run build && concurrently \"nodemon backend/dist/server.js\" \"cd frontend && npm run dev\"",
    "host": "npm --prefix frontend run host",
    "host:full": "concurrently \"tsc -w -p backend/tsconfig.json\" \"nodemon backend/dist/server.js\" \"npm --prefix frontend run host\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
